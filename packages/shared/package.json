{
  "name": "@picsonar/shared",
  "version": "1.0.0",
  "description": "Shared types, schemas, constants and validators for PicSonar (frontend + backend).",
  "private": true,
  "main": "./src/index.ts",
  "types": "./src/index.ts",
  "exports": {
    ".": "./src/index.ts",
    "./schemas": "./src/schemas/index.ts",
    "./constants": "./src/constants/index.ts",
