    "@tanstack/react-query": "^5.90.12",
    "@types/uuid": "^10.0.0",
    "axios": "^1.6.2",
    "browser-image-compression": "^2.0.2",
    "i18next": "^25.8.14",
    "i18next-browser-languagedetector": "^8.2.1",
    "i18next-http-backend": "^3.0.2",
    "jszip": "^3.10.1",
    "qrcode": "^1.5.3",
    "react": "^18.2.0",
    "react-dom": "^18.2.0",
    "react-hook-form": "^7.53.1",
    "react-hot-toast": "^2.4.1",
    "react-i18next": "^16.5.6",
