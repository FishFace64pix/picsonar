# Frontend env — copy to .env. Only VITE_* vars are exposed to the browser.
# Vite snapshots these at build time; restart `npm run dev` after any change.

# Backend base URL. `serverless offline` mounts the stage into the path:
#   http://localhost:3000/<stage>
# so for stage=dev the base becomes:
VITE_API_BASE_URL=http://localhost:3000/dev

# Stripe publishable (TEST) key — sibling of STRIPE_SECRET_KEY in backend/.env
VITE_STRIPE_PUBLISHABLE_KEY=pk_test_xxx

# Mock mode — skip the real API and hydrate fixtures. Useful for UI-only work.
VITE_USE_MOCK=false

# Optional observability
VITE_SENTRY_DSN=
VITE_GA_ID=
