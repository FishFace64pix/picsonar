# =========================================================
# EventFaceMatch / PicSonar — Backend environment template
# Copy to .env and fill. NEVER commit real values.
# In production these come from AWS Secrets Manager.
# =========================================================

NODE_ENV=development
AWS_REGION=eu-central-1
STAGE=dev

# --- Auth ---
# REQUIRED. 32+ chars high-entropy string.
# Generate:  node -e "console.log(require('crypto').randomBytes(64).toString('hex'))"
JWT_SECRET=
JWT_REFRESH_SECRET=

# --- DynamoDB tables (auto-injected by serverless, overrides for local) ---
USERS_TABLE=eventfacematch-users-dev
EVENTS_TABLE=eventfacematch-events-dev
PHOTOS_TABLE=eventfacematch-photos-dev
FACES_TABLE=eventfacematch-faces-dev
ORDERS_TABLE=eventfacematch-orders-dev
AUDIT_LOGS_TABLE=eventfacematch-audit-logs-dev
SYSTEM_STATS_TABLE=eventfacematch-system-stats-dev
RATE_LIMITS_TABLE=eventfacematch-rate-limits-dev
REVOKED_TOKENS_TABLE=eventfacematch-revoked-tokens-dev

# --- S3 buckets ---
RAW_PHOTOS_BUCKET=eventfacematch-raw-photos-dev
FACE_INDEX_BUCKET=eventfacematch-face-index-dev
QR_CODES_BUCKET=eventfacematch-qr-codes-dev
INVOICES_BUCKET=eventfacematch-invoices-dev

# --- Rekognition ---
REKOGNITION_COLLECTION_ID=eventfacematch-collection-dev

# --- Stripe (sole payment rail) ---
# Use TEST keys in local dev (Dashboard → Developers → API keys).
# STRIPE_WEBHOOK_SECRET comes from `stripe listen` output — see
# docs/LOCAL_DEVELOPMENT.md §6. Romanian ANAF e-Factura submission is done
# manually by the accountant from the Stripe monthly export — we do NOT
# integrate Oblio or any other billing provider from code.
STRIPE_SECRET_KEY=sk_test_xxx
STRIPE_WEBHOOK_SECRET=whsec_xxx
STRIPE_PUBLISHABLE_KEY=pk_test_xxx

# --- Email (Brevo / Sendinblue SMTP works out of the box; for throwaway
# inbox in dev, `npx create-ethereal-email` gives you a disposable SMTP) ---
SMTP_HOST=smtp-relay.brevo.com
SMTP_PORT=587
SMTP_USER=
SMTP_PASS=
EMAIL_FROM=no-reply@picsonar.com
EMAIL_FROM_NAME=PicSonar

# --- Frontend origins (CSV, CORS allowlist) ---
ALLOWED_ORIGINS=http://localhost:5173,https://picsonar.com,https://www.picsonar.com,https://app.picsonar.com

# --- Frontend URL (used in password-reset / magic links etc.) ---
FRONTEND_URL=http://localhost:5173

# --- Misc ---
LOG_LEVEL=debug
SIGNED_URL_TTL_SECONDS=3600
MAX_UPLOAD_BYTES=15728640
