{
  "name": "eventfacematch-backend",
  "version": "1.0.0",
  "description": "Serverless backend for EventFaceMatch",
  "main": "index.js",
  "scripts": {
    "deploy": "serverless deploy",
    "deploy:dev": "serverless deploy --stage dev",
    "deploy:staging": "serverless deploy --stage staging",
    "deploy:prod": "serverless deploy --stage prod",
    "remove": "serverless remove",
    "logs": "serverless logs -f",
    "invoke": "serverless invoke -f",
    "dev": "serverless offline start --httpPort 3000 --stage dev",
    "typecheck": "tsc --noEmit",
    "lint": "eslint \"functions/**/*.ts\" \"src/**/*.ts\" --max-warnings 0",
    "test": "jest",
    "test:watch": "jest --watch",
    "test:coverage": "jest --coverage",
    "seed:test-user": "ts-node scripts/seedTestUser.ts",
    "ensure:rekognition": "ts-node scripts/ensureRekognitionCollection.ts"
  },
  "dependencies": {
    "@aws-lambda-powertools/logger": "^2.10.0",
    "@aws-lambda-powertools/metrics": "^2.10.0",
    "@aws-lambda-powertools/tracer": "^2.10.0",
    "@aws-sdk/client-dynamodb": "^3.490.0",
    "@aws-sdk/client-rekognition": "^3.490.0",
    "@aws-sdk/client-s3": "^3.490.0",
    "@aws-sdk/client-secrets-manager": "^3.490.0",
    "@aws-sdk/lib-dynamodb": "^3.490.0",
    "@aws-sdk/lib-storage": "^3.490.0",
    "@aws-sdk/s3-request-presigner": "^3.490.0",
    "@aws-sdk/util-dynamodb": "^3.490.0",
    "@picsonar/shared": "*",
    "@types/jsonwebtoken": "^9.0.10",
    "aws-lambda": "^1.0.7",
    "bcryptjs": "^2.4.3",
    "file-type": "^19.6.0",
    "jimp": "^1.6.0",
    "jsonwebtoken": "^9.0.3",
    "jszip": "^3.10.1",
    "lambda-multipart-parser": "^1.0.1",
    "nodemailer": "^8.0.1",
    "pdf-lib": "^1.17.1",
    "qrcode": "^1.5.3",
    "stripe": "^22.0.0",
    "uuid": "^9.0.1",
    "zod": "^4.1.13"
  },
  "devDependencies": {
    "@types/aws-lambda": "^8.10.130",
    "@types/bcryptjs": "^2.4.6",
    "@types/jest": "^30.0.0",
    "@types/node": "^20.19.26",
    "@types/nodemailer": "^7.0.11",
    "@types/qrcode": "^1.5.5",
    "@types/uuid": "^9.0.7",
    "@typescript-eslint/eslint-plugin": "^7.0.0",
    "@typescript-eslint/parser": "^7.0.0",
    "aws-sdk-client-mock": "^4.1.0",
    "esbuild": "^0.27.1",
    "eslint": "^8.55.0",
    "jest": "^30.2.0",
    "serverless": "^3.38.0",
    "serverless-dotenv-plugin": "^6.0.0",
    "serverless-esbuild": "^1.56.1",
    "serverless-offline": "^13.3.0",
    "ts-jest": "^29.4.6",
    "ts-node": "^10.9.2",
    "typescript": "^5.2.2"
  }
}
